# Copy to .env and adjust before deploying
POSTGRES_PASSWORD=pick-a-strong-db-password
SMARTSPLIT_SECRET=pick-a-long-random-jwt-secret
# Optional: enables the Groq fallback for photo/scanned receipts
GROQ_API_KEY=
# Groq retires models periodically. If parsing starts failing with a 404, pick a
# current one from https://console.groq.com/docs/models — the vision model must
# support image input.
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# Host port the app is served on
SMARTSPLIT_PORT=8080

# --- Sign in with Google ---
# Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add your app's URL to
# "Authorised JavaScript origins" (e.g. http://localhost:8080).
# Only the client ID is needed — the browser flow uses no client secret.
# Leave empty to hide the Google button.
GOOGLE_CLIENT_ID=

# --- Email one-time codes (passwordless login + email verification) ---
# Leave SMTP_HOST empty to run without a mail account: codes are printed to the
# backend logs and returned by the API instead of being emailed (local dev only).
#
# Gmail: turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste the 16 characters below.
# Use that App Password here — never your normal Google password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com
SMTP_FROM_NAME=SmartSplit
OTP_TTL_MINUTES=10
